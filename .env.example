# Smart Fuel Pass
SMARTFUELPASS_BASE_URL=https://portal.smartfuelpass.com/
SMARTFUELPASS_LOGIN_URL=https://portal.smartfuelpass.com/User/Login
SMARTFUELPASS_EMAIL=user@example.com
SMARTFUELPASS_PASSWORD=change-me
SMARTFUELPASS_REPORT_OUTPUT_PATH=data/smartfuelpass/reporting_snapshot.json
SMARTFUELPASS_REPORT_TARGETS=dashboard=https://portal.smartfuelpass.com/
SMARTFUELPASS_REQUEST_TIMEOUT_SECONDS=30
SMARTFUELPASS_LOGIN_TIMEOUT_SECONDS=300
SMARTFUELPASS_DASHBOARD_PATH=/Fuel/Merchant/Dashboard?contractId=12147&accountId=0
SMARTFUELPASS_CHARGING_SESSIONS_LABEL=Nabíjecí relace
SMARTFUELPASS_SUMMARY_LABEL=Celkově
SMARTFUELPASS_REPORT_SUBJECT_NAME=ARMEX HOLDING, a.s.
SMARTFUELPASS_LOGO_PATH=data/smartfuelpass/smfp_logo_white.svg
SMARTFUELPASS_ARMEX_LOGO_PATH=data/ARMEX/logo_ARMEX.png
SMARTFUELPASS_WEEKLY_REPORT_RECIPIENTS=user@example.com
SMARTFUELPASS_WEEKLY_REPORT_SENDER_ALIAS=upozorneni@example.com
SMARTFUELPASS_TABLE_WAIT_TIMEOUT_SECONDS=45

# Dashboard API
API_TITLE=Monitoring Platform API
API_VERSION=0.1.0
# Automaticka FastAPI dokumentace je ve vychozim produkcnim nastaveni vypnuta.
API_ENABLE_DOCS=false
# API_TOKEN_SECRET je povinny. Nenechavej placeholder change-me.
API_TOKEN_SECRET=change-me
# Pevny maximalni cas jedne prihlasene relace.
API_TOKEN_EXPIRY_MINUTES=480
# Kratka klouzava platnost obnovovana aktivnim dashboardem.
API_SESSION_INACTIVITY_MINUTES=30
# Vychozi Windows cesta: %PROGRAMDATA%\monitorovaci_platforma\logs\auth_audit.jsonl
# AUTH_AUDIT_LOG_PATH=C:\ProgramData\monitorovaci_platforma\logs\auth_audit.jsonl
AUTH_AUDIT_RETENTION_DAYS=90
AUTH_ADMIN_FAILURE_ALERT_LIMIT=3
AUTH_SECURITY_ALERT_WINDOW_SECONDS=900
DASHBOARD_API_BASE_URL=http://127.0.0.1:8000

# Scheduler
SCHEDULER_MISFIRE_GRACE_SECONDS=900
DATABASE_ERROR_RECIPIENTS=ops@example.com
# Volitelne; pri prazdne hodnote se pouzije DATABASE_ERROR_RECIPIENTS.
RUNTIME_ERROR_RECIPIENTS=ops@example.com
# Aktivni dashboard admin prijemci dostanou technicke detaily.
# Ostatni nebo neovereni prijemci dostanou pouze strucny text alertu.

VODOMERY_MONTHLY_CONSUMPTION_REPORT_RECIPIENTS=ops@example.com
