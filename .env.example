VODOMERY_DAILY_BRANCH_REPORT_SENDER_ALIAS=upozorneni@example.com
VODOMERY_WEEKLY_BRANCH_REPORT_RECIPIENTS=ops@example.com
VODOMERY_WEEKLY_BRANCH_REPORT_SENDER_ALIAS=upozorneni@example.com
